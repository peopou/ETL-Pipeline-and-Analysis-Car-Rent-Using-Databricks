{
  "datasets": [
    {
      "name": "86fd2587",
      "displayName": "Top Customers Ranked by Rental Count and Spending",
      "queryLines": [
        "select\n",
        "  customer_name,\n",
        "  count(*) as total_rental,\n",
        "  sum(total_amount) as total_spent\n",
        "from gold.fact_rental f\n",
        "join gold.dim_customer cs\n",
        "  on f.customer_id = cs.customer_id\n",
        "group by 1\n",
        "order by 2 desc\n",
        "limit 10\n"
      ]
    },
    {
      "name": "e5092517",
      "displayName": "Top Customers by Rental Activity and Spending",
      "queryLines": [
        "select\n",
        "  customer_name,\n",
        "  count(*) as total_rental,\n",
        "  sum(total_amount) as total_spent\n",
        "from gold.fact_rental f\n",
        "join gold.dim_customer cs\n",
        "  on f.customer_id = cs.customer_id\n",
        "group by 1\n",
        "order by 2 desc\n",
        "limit 10\n"
      ]
    },
    {
      "name": "b2e0255c",
      "displayName": "Top Vehicle Usage and Rental Duration Summary",
      "queryLines": [
        "select\n",
        "  v.vehicle_brand,\n",
        "  v.vehicle_model,\n",
        "  v.vehicle_type,\n",
        "  count(*) as total_usage,\n",
        "  sum(f.rental_duration_days) as total_days\n",
        "from gold.fact_rental f\n",
        "join gold.dim_vehicle v\n",
        "  on f.vehicle_id = v.vehicle_id\n",
        "group by 1,2,3\n",
        "order by 4 desc\n",
        "limit 10"
      ]
    },
    {
      "name": "436fa32c",
      "displayName": "Location Transaction Summary Report",
      "queryLines": [
        "select\n",
        "  l.location_name,\n",
        "  l.location_city,\n",
        "  count(*) as total_transaction\n",
        "from gold.fact_rental f\n",
        "join gold.dim_location l\n",
        "  on f.pickup_location_key = l.location_id\n",
        "group by 1,2\n",
        "order by 3 desc"
      ]
    },
    {
      "name": "69f17ca1",
      "displayName": "Untitled dataset",
      "queryLines": [
        "select\n",
        "            d.month,\n",
        "            sum(f.total_amount) as total_revenue\n",
        "        from gold.fact_rental f\n",
        "        join gold.dim_date d\n",
        "            on f.rental_date = d.date\n",
        "         group by 1\n",
        "         order by 1"
      ]
    }
  ],
